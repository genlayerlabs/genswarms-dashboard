# subzero-swarm-dashboard — copy to .env and adjust. Read-only; HTTP/WS only.

# The swarm read API (must be the in-BEAM endpoint — see README prerequisite).
export SWARM_API_URL="http://127.0.0.1:4000"
export SWARM_NAME="wingston"
# export SWARM_WS_URL="ws://127.0.0.1:4000"     # derived from SWARM_API_URL if unset
# export SWARM_API_TOKEN="..."                  # = the swarm's DASHBOARD_API_TOKEN

# LLM router usage (optional; the Usage page degrades gracefully without it).
# export ROUTER_USAGE_URL="https://router.ygr.ai/v1/usage"
# export ROUTER_API_KEY="wd_..."

# Dashboard server.
export PORT="4100"
# export DASHBOARD_POLL_MS="3000"
# export DASHBOARD_USER="admin"
# export DASHBOARD_PASS="change-me"
