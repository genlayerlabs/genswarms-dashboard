# subzero-swarm-dashboard — copy to .env and adjust. Read-only; HTTP + WS only.
#
# The dashboard talks to ONE host endpoint exposed by the orchestrator (the read-only
# Wingston.DashboardEndpoint). That endpoint serves the HTTP read API (/api/swarms/:name/
# dashboard|sessions/:id/history|sessions/:id/logs|events) and the live /swarm WebSocket, all
# in the same BEAM as the swarm. The engine's own control API is NOT exposed.

# ── Swarm read surface (HTTP) — the host endpoint, default port 4001. ────────────────────────
#   LOCAL dev: orchestrator runs token-free + loopback, so plain http to 127.0.0.1:4001.
#   PROD: the dashboard is on a SEPARATE host — reach the orchestrator over a private network
#         (Tailscale/WireGuard) or an SSH tunnel (no public TLS cert needed), and set the token.
export SWARM_API_URL="http://127.0.0.1:4001"
export SWARM_NAME="wingston"

# Live event feed (WebSocket). Defaults to SWARM_API_URL if unset; the app appends
# /swarm/websocket and rewrites http->ws / https->wss.
# export SWARM_WS_URL="http://127.0.0.1:4001"

# Bearer token — must equal the orchestrator's DASHBOARD_API_TOKEN. Leave UNSET only for a
# loopback/token-free local orchestrator; REQUIRED in prod (sent as the HTTP Bearer header and
# the x-dashboard-token WS header).
# export SWARM_API_TOKEN="..."

# ── LLM router usage (Usage page). Optional — the page degrades gracefully without it. ───────
# ROUTER_USAGE_URL is the full usage endpoint; ROUTER_API_KEY is the consumer key (the same key
# the swarm's agents use, i.e. the orchestrator's SUBZEROCLAW_API_KEY).
# export ROUTER_USAGE_URL="https://router.ygr.ai/v1/usage"
# export ROUTER_API_KEY="wd_..."

# ── Dashboard server. ────────────────────────────────────────────────────────────────────────
export PORT="4100"
# export DASHBOARD_POLL_MS="3000"
# export DASHBOARD_USER="admin"
# export DASHBOARD_PASS="change-me"
