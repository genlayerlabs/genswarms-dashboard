# Copy to .env for `docker compose up`.  Generate SECRET_KEY_BASE with:
#   docker run --rm subzero-swarm-dashboard:latest bin/subzero_swarm_dashboard eval "IO.puts(:crypto.strong_rand_bytes(48) |> Base.encode64())"
# (or `mix phx.gen.secret` if you have the toolchain locally)

# --- required ---
SECRET_KEY_BASE=
# The swarm read API base — must be reachable FROM the dashboard container.
#   swarm on the host (Wingston launcher): http://host.docker.internal:4000
#   swarm as a compose service:            http://<swarm-service>:4000
SWARM_API_URL=http://host.docker.internal:4000
# MUST match the swarm's DASHBOARD_API_TOKEN (gates HTTP reads + the WS event socket).
SWARM_API_TOKEN=

# --- recommended ---
PHX_HOST=localhost
SWARM_NAME=wingston
DASHBOARD_USER=
DASHBOARD_PASS=

# --- optional ---
# SWARM_WS_URL=            # auto-derived from SWARM_API_URL unless the WS base differs
# ROUTER_USAGE_URL=https://router.ygr.ai/v1/usage
# ROUTER_API_KEY=
# DASHBOARD_POLL_MS=3000
